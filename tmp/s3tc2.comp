    //     uint local_linear_index = gl_LocalInvocationID.y * 16u + gl_LocalInvocationID.x;
        
    //     if (pc.format == FORMAT_DXT1_RGB || pc.format == FORMAT_DXT1_SRGB || 
    //         pc.format == FORMAT_DXT1_RGBA || pc.format == FORMAT_DXT1_SRGBA) {
            
