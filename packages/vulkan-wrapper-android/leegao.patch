+static VkResult CreateStagingBuffer(
+   struct wrapper_device* _device,
+   VkDeviceSize size,
+   VkBufferUsageFlags usage,
+   VkMemoryPropertyFlags properties,
+   VkBuffer* buffer,
+   VkDeviceMemory* bufferMemory) {
