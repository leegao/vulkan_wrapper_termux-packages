+#include "rgtc.h"
+#include "bitextract.h"
+#include "compute_shader_mode.h"
+
+#define VK_FORMAT_BC1_RGB_UNORM_BLOCK 131
+#define VK_FORMAT_BC1_RGB_SRGB_BLOCK 132
+#define VK_FORMAT_BC1_RGBA_UNORM_BLOCK 133
+#define VK_FORMAT_BC1_RGBA_SRGB_BLOCK 134
+#define VK_FORMAT_BC2_UNORM_BLOCK 135
+#define VK_FORMAT_BC2_SRGB_BLOCK 136
+#define VK_FORMAT_BC3_UNORM_BLOCK 137
+#define VK_FORMAT_BC3_SRGB_BLOCK 138
+#define VK_FORMAT_BC4_UNORM_BLOCK 139
+#define VK_FORMAT_BC4_SNORM_BLOCK 140
+#define VK_FORMAT_BC5_UNORM_BLOCK 141
+#define VK_FORMAT_BC5_SNORM_BLOCK 142
+
+// The shader will be dispatched with one invocation per pixel of the output image.
+layout (local_size_x = 8, local_size_y = 8, local_size_z = 1) in;
+
+// --- Push Constants ---
+// We use push constants to pass image parameters efficiently.
+layout(push_constant) uniform PushConstants {
+    // Format of the source compressed data. We'll use Vulkan enum values.
+    // VK_FORMAT_BC1_RGB_UNORM_BLOCK = 131
+    // VK_FORMAT_BC2_UNORM_BLOCK = 135
+    // VK_FORMAT_BC3_UNORM_BLOCK = 137
+    // VK_FORMAT_BC4_UNORM_BLOCK = 143
+    // VK_FORMAT_BC5_UNORM_BLOCK = 145
+    uint srcFormat;
+
+    // The dimensions of the source compressed data buffer.
+    uint srcRowLength;   // Stride in pixels of the source data
+    uint srcImageHeight;
+
+    // The destination image parameters.
+    int offsetx;
+    int offsety;
+    uint dst_width;
+    uint dst_height;
+
+    uint srcBufferSize;
+
+    uint unsupportedBitsBc; // bitmask
+    uint watercoloredBitsBc;
+    uint watermarkerSize;
+} push_constants;
+
+// --- Buffers ---
+// Source buffer containing the compressed BCn blocks.
+// We read it as an array of 32-bit uints for easier bit manipulation.
+layout(set = 0, binding = 0) readonly buffer SourceBuffer {
+    uint data[];
+} srcBuffer;
+#ifdef USE_IMAGE_VIEW_OUTPUT
+// Destination image view for the decompressed RGBA8 data.
+// We use a storage image to write the decompressed pixels directly.
+layout(set = 0, binding = 1, rgba8) uniform writeonly image2D dstImage;
+#else
+// Destination buffer for the decompressed RGBA8 data.
+// We now use a raw storage buffer of uints.
+layout(set = 0, binding = 1) writeonly buffer DestinationBuffer {
+    uint data[];
+} dstBuffer;
+#endif
+
+// --- BC2 Helper ---
+// Decodes the explicit 4-bit alpha for a single pixel from a BC2 alpha block.
+float decode_alpha_4bit(uvec2 payload, int pixel)
+{
+    uint offset = uint(pixel) * 4;
+    // Each pixel's alpha is a 4-bit value. This extracts the correct nibble.
+    return float((payload[offset >> 5] >> (offset & 31)) & 0xf) / 15.0;
+}
+
+vec3 decode_endpoint_color(uint color)
+{
+    ivec3 c = ivec3(color) >> ivec3(11, 5, 0);
+    c &= ivec3(31, 63, 31);
+    return vec3(c) / vec3(31.0, 63.0, 31.0);
+}
+
+// Decodes color endpoints and determines if the block is in opaque (4-color) mode.
+// This version is updated to correctly handle BC1, BC2, and BC3 color blocks.
+bool decode_endpoints_color(uint payload, out vec3 ep0, out vec3 ep1, uint src_format)
+{
+    uint color0 = payload & 0xffffu;
+    uint color1 = payload >> 16u;
+
+    // The color block is always in 4-color mode if a separate alpha block (BC2, BC3) is present.
+    // Otherwise, for BC1, it depends on the endpoint color values.
+    // BC2 formats are 135-136, BC3 are 137-138.
+    bool has_separate_alpha = (src_format >= VK_FORMAT_BC2_UNORM_BLOCK && src_format <= VK_FORMAT_BC3_SRGB_BLOCK);
+    bool opaque_mode = has_separate_alpha || (color0 > color1);
+
+    ep0 = decode_endpoint_color(color0);
+    ep1 = decode_endpoint_color(color1);
+    return opaque_mode;
+}
+
+
+vec4 interpolate_endpoint_color(vec3 ep0, vec3 ep1, int bits, bool opaque_mode)
+{
+    // Note: this was changed from the original into a direct LUT implementation of BC1 
+    // This gets rid of the clever use of mix and if-branches to avoid divergence
+    // This is counterintuitive as the prior implementation avoids computing the unnecessary
+    // palette entries, but FLOPs are relatively low-cost, and divergence is the main
+    // culprit of stalling in the GPU.
+    if (opaque_mode)
+    {
+        // 4-color mode (BC1 opaque, BC2, BC3, BC5)
+        vec3 palette[4];
+        palette[0] = ep0;
+        palette[1] = ep1;
+        palette[2] = (2.0 * ep0 + 1.0 * ep1) / 3.0;
+        palette[3] = (1.0 * ep0 + 2.0 * ep1) / 3.0;
+        return vec4(palette[bits], 1.0);
+    }
+    else
+    {
+        // 3-color + transparent mode (BC1 with alpha)
+        vec3 palette[3];
+        palette[0] = ep0;
+        palette[1] = ep1;
+        palette[2] = 0.5 * (ep0 + ep1);
+
+        if (bits == 3) {
+            return vec4(0.0); // Transparent black
+        } else {
+            return vec4(palette[bits], 1.0);
+        }
+    }
+}
+
+
+vec4 decode_color_bc1_3(uvec2 color_payload, uint linear_pixel, uint src_format)
+{
+    vec3 ep0, ep1;
+    bool opaque_mode = decode_endpoints_color(color_payload.x, ep0, ep1, src_format);
+    return interpolate_endpoint_color(ep0, ep1, int((color_payload.y >> (2 * linear_pixel)) & 3), opaque_mode);
+}
+
+// --- Shared Memory for Optimization ---
+shared uvec4 shared_block_data[4]; // One 128-bit block for each 4x4 quad-group in the 8x8 workgroup.
+
+void main() {
+    // uvec4 shared_block_data[4];
+
+    bool is_bc1 = push_constants.srcFormat >= VK_FORMAT_BC1_RGB_UNORM_BLOCK && push_constants.srcFormat <= VK_FORMAT_BC1_RGBA_SRGB_BLOCK;
+    bool is_bc4 = push_constants.srcFormat == VK_FORMAT_BC4_UNORM_BLOCK || push_constants.srcFormat == VK_FORMAT_BC4_SNORM_BLOCK;
+    bool use_2_quads = is_bc1 || is_bc4;
+
+    ivec2 pixel_coord = ivec2(gl_WorkGroupID.xy) * 8 + ivec2(gl_LocalInvocationID.xy);
+    ivec2 final_dst_coord = ivec2(push_constants.offsetx, push_constants.offsety) + pixel_coord;
+    if (final_dst_coord.x >= push_constants.dst_width || final_dst_coord.y >= push_constants.dst_height) {
+        return;
+    }
+
+    // Check the bitmask
+    bool is_masked = (push_constants.unsupportedBitsBc & (1 << (push_constants.srcFormat - 131))) != 0;
+    bool is_watermarked = ((push_constants.watercoloredBitsBc & (1 << (push_constants.srcFormat - 131))) != 0)
+        && pixel_coord.x < push_constants.watermarkerSize && pixel_coord.y < push_constants.watermarkerSize;
+    if (is_masked || is_watermarked) {
+#define RETURN(r,g,b) imageStore(dstImage, final_dst_coord, vec4(r/256.0, g/256.0, b/256.0, 1.0)); break
+#ifdef USE_IMAGE_VIEW_OUTPUT
+        switch (push_constants.srcFormat) {
+        // See https://sashamaps.net/docs/resources/20-colors/
+        case 131:
+            RETURN(0x80, 0, 0); // Maroon
+        case 132:
+            RETURN(0x9a, 0x63, 0x24); // Brown
+        case 133:
+            RETURN(0x80, 0x80, 0); // Olive
+        case 134:
+            RETURN(0x46, 0x99, 0x90); // Dark Teal
+        case 135:
+            RETURN(0x00, 0x00, 0x75); // Navy
+        case 136:
+            RETURN(0xff, 0xfa, 0xc8); // Beige
+        case 137:
+            RETURN(0xf5, 0x82, 0x31); // Orange
+        case 138:
+            RETURN(0xff, 0xe1, 0x19); // Yellow
+        case 139:
+            RETURN(0xbf, 0xef, 0x45); // Lime green
+        case 140:
+            RETURN(0x3c, 0xb4, 0x4b); // Green
+        case 141:
+            RETURN(0x42, 0xd4, 0xf4); // Cyan
+        case 142:
+            RETURN(0x91, 0x1e, 0xb4); // Purple
+        default:
+            RETURN(0xff, 0xff, 0xff); // White
+        }
+#endif
+        return;
+    }
+
+    // Calculate the block coordinate
+    uint block_stride = (push_constants.srcRowLength + 3u) / 4;
+    uint local_thread_id = gl_LocalInvocationID.y * 8u + gl_LocalInvocationID.x;
+    if (local_thread_id < 4u) {
+        // Calculate source block coordinates on the 2x2 = 4 grid
+        uvec2 local_block_coord = uvec2(local_thread_id % 2u, local_thread_id / 2u);
+        uvec2 src_block_coord = uvec2(gl_WorkGroupID.xy) * 2 + local_block_coord;
+        
+        // Check if source block is within compressed texture bounds
+        // Each block is a 4x4 patch of texels
+        uint src_blocks_width = (push_constants.dst_width + 3u) / 4u;   // Blocks, not pixels
+        uint src_blocks_height = (push_constants.dst_height + 3u) / 4u;
+        if (src_block_coord.x < src_blocks_width && src_block_coord.y < src_blocks_height) {
+            uint src_block_index = uint(src_block_coord.y) * block_stride + uint(src_block_coord.x);
+            uint data_offset = src_block_index * (use_2_quads ? 2u : 4u);
+            uint data0 = srcBuffer.data[data_offset];
+            uint data1 = srcBuffer.data[data_offset + 1u];
+            if (use_2_quads) {
+                shared_block_data[local_thread_id] = uvec4(data0, data1, 0u, 0u);
+            } else {
+                uint data2 = srcBuffer.data[data_offset + 2u];
+                uint data3 = srcBuffer.data[data_offset + 3u];
+                shared_block_data[local_thread_id] = uvec4(data0, data1, data2, data3);
+            }
+        } else {
+            shared_block_data[local_thread_id] = uvec4(0);
+        }
+    }
+
+    // Synchronize to ensure all loaders have written their data before any invocation reads it
+    barrier();
+    
+    uvec2 block_coord = gl_LocalInvocationID.xy / 4;
+    uint block_index = block_coord.y * 2u + block_coord.x;
+    uvec4 payload = shared_block_data[block_index];
+
+    // Find the specific pixel this thread is responsible for within its 4x4 block
+    ivec2 tile_coord = pixel_coord % 4;
+    uint linear_pixel = 4 * tile_coord.y + tile_coord.x;
+
+    vec4 decompressed_color;
+    uint format = push_constants.srcFormat;
+
+    bool is_srgb = false;
+    if (format == VK_FORMAT_BC1_RGB_SRGB_BLOCK || format == VK_FORMAT_BC1_RGBA_SRGB_BLOCK 
+        || format == VK_FORMAT_BC2_SRGB_BLOCK || format == VK_FORMAT_BC3_SRGB_BLOCK) {
+        is_srgb = true;
+    }
+
+    if (format >= VK_FORMAT_BC1_RGB_UNORM_BLOCK && format <= VK_FORMAT_BC1_RGBA_SRGB_BLOCK) {
+        // VK_FORMAT_BC1_RGB_UNORM_BLOCK = 131,
+        // VK_FORMAT_BC1_RGB_SRGB_BLOCK = 132,
+        // VK_FORMAT_BC1_RGBA_UNORM_BLOCK = 133,
+        // VK_FORMAT_BC1_RGBA_SRGB_BLOCK = 134,
+        // BC1 blocks are 8 bytes (2 uints)
+        uvec2 block_data = uvec2(payload.xy);
+        decompressed_color = decode_color_bc1_3(block_data, linear_pixel, format);
+        // Check for VK_FORMAT_BC1_RGB_UNORM_BLOCK/VK_FORMAT_BC1_RGB_SRGB_BLOCK without alpha
+        if (format == VK_FORMAT_BC1_RGB_UNORM_BLOCK || format == VK_FORMAT_BC1_RGB_SRGB_BLOCK) {
+            decompressed_color.a = 1.0;
+        }
+    } else if (format >= VK_FORMAT_BC2_UNORM_BLOCK && format <= VK_FORMAT_BC2_SRGB_BLOCK) {
+        // VK_FORMAT_BC2_UNORM_BLOCK = 135,
+        // VK_FORMAT_BC2_SRGB_BLOCK = 136,
+        // BC2 blocks are 16 bytes (4 uints)
+        uvec2 alpha_payload = payload.xy;
+        uvec2 color_payload = payload.zw;
+        decompressed_color = decode_color_bc1_3(color_payload, linear_pixel, format);
+        decompressed_color.a = decode_alpha_4bit(alpha_payload, int(linear_pixel));
+    } else if (format == VK_FORMAT_BC3_UNORM_BLOCK || format == VK_FORMAT_BC3_SRGB_BLOCK) {
+        // VK_FORMAT_BC3_UNORM_BLOCK = 137,
+        // VK_FORMAT_BC3_SRGB_BLOCK = 138,
+        // BC3 blocks are 16 bytes (4 uints)
+        uvec2 alpha_payload = payload.xy;
+        uvec2 color_payload = payload.zw;
+        decompressed_color = decode_color_bc1_3(color_payload, linear_pixel, format);
+        decompressed_color.a = decode_alpha_rgtc(alpha_payload, int(linear_pixel));
+    } else if (format == VK_FORMAT_BC4_UNORM_BLOCK || format == VK_FORMAT_BC4_SNORM_BLOCK) {
+        // VK_FORMAT_BC4_UNORM_BLOCK = 139,
+        // VK_FORMAT_BC4_SNORM_BLOCK = 140,
+        // BC4 blocks are 8 bytes (2 uints)
+        uvec2 block_data = uvec2(payload.xy);
+        float r;
+        if (format == VK_FORMAT_BC4_UNORM_BLOCK) { // UNORM
+            r = decode_alpha_rgtc(block_data, int(linear_pixel));
+        } else { // SNORM
+            r = decode_alpha_rgtc_snorm(block_data, int(linear_pixel));
+        }
+        decompressed_color = vec4(r, r, r, 1.0);
+    } else if (format == VK_FORMAT_BC5_UNORM_BLOCK || format == VK_FORMAT_BC5_SNORM_BLOCK) {
+        // VK_FORMAT_BC5_UNORM_BLOCK = 141,
+        // VK_FORMAT_BC5_SNORM_BLOCK = 142,
+        // BC5 blocks are 16 bytes (4 uints)
+        uvec2 r_payload = payload.xy;
+        uvec2 g_payload = payload.zw;
+        float r, g;
+        if (format == VK_FORMAT_BC5_UNORM_BLOCK) { // UNORM
+            r = decode_alpha_rgtc(r_payload, int(linear_pixel));
+            g = decode_alpha_rgtc(g_payload, int(linear_pixel));
+        } else { // SNORM
+            r = decode_alpha_rgtc_snorm(r_payload, int(linear_pixel));
+            g = decode_alpha_rgtc_snorm(g_payload, int(linear_pixel));
+        }
+        decompressed_color = vec4(r, g, 0.0, 1.0);
+    } else {
+        // Unsupported format, write an error color (magenta)
+        decompressed_color = vec4(1.0, 0.0, 1.0, 1.0);
+    }
+
+    if (is_srgb) {
+        decompressed_color.rgb = srgb_to_linear(decompressed_color.rgb);
+    }
+
+#ifdef USE_IMAGE_VIEW_OUTPUT
+    imageStore(dstImage, final_dst_coord, decompressed_color);
+#else
+    // Calculate the linear index into the destination buffer using its row length (dst_width is the stride)
+    int dst_index = int(pixel_coord.y * push_constants.dst_width + pixel_coord.x);
+    dstBuffer.data[dst_index] = packUnorm4x8(decompressed_color);
+#endif
+}
diff --git a/src/vulkan/wrapper/spirv_edit.cpp b/src/vulkan/wrapper/spirv_edit.cpp
new file mode 100644
index 00000000000..cbef91486c0
--- /dev/null
+++ b/src/vulkan/wrapper/spirv_edit.cpp
@@ -0,0 +1,162 @@
+#include "spirv_edit.h"
+#include <iostream>
+#include <vector>
+#include <string>
+
+extern "C" {
+#include "wrapper_log.h"
+#include "wrapper_debug.h"
+}
+
+#include "spirv-tools/spirv-tools/optimizer.hpp"
+#include "spirv-tools/spirv-tools/libspirv.hpp"
+
+extern "C"
+void log_disassembly_to_cmd_log(const uint32_t* spirv_binary, size_t spirv_word_count) {
+    spvtools::SpirvTools tools(SPV_ENV_VULKAN_1_1_SPIRV_1_4);
+    std::string disassembly;
+    tools.Disassemble({spirv_binary, spirv_binary + spirv_word_count}, &disassembly, SPV_BINARY_TO_TEXT_OPTION_FRIENDLY_NAMES);
+    VK_CMD_PRINTF("%s", disassembly.c_str());
+}
+
+static void print_spirv_code(const char* prefix, int size, const uint32_t* pCode) {
+    if (size == 0 || !pCode) {
+        return;
+    }
+    // Print the SPIR-V code in int32 hex with 32 bytes (8 uint32_t) per line
+    int i = 0;
+    while (i < size / 4) {
+        if (i + 7 < size / 4) {
+            WLOG("%s.spirv(%p)[%04x]: %08x %08x %08x %08x %08x %08x %08x %08x", prefix, pCode, 4 * i,
+                          pCode[i], pCode[i + 1], pCode[i + 2], pCode[i + 3],
+                          pCode[i + 4], pCode[i + 5], pCode[i + 6], pCode[i + 7]);
+            i += 8;
+            continue;
+        }
+
+        if (i % 8 == 0) {
+            WLOG("%s.spirv(%p)[%04x]: ", prefix, pCode, 4 * i);
+        }
+        WLOG("%08x ", pCode[i]);
+        i++;
+    }
+}
+
+void LogDisassembly(const std::string& title, const std::vector<uint32_t>& binary, int id) {
+    if (!CHECK_FLAG("LOG_DISASSEMBLY") && !CAN_LOG(LOG_LEVEL_ALL)) {
+        return;
+    }
+    spvtools::SpirvTools tools(SPV_ENV_VULKAN_1_1_SPIRV_1_4);
+    std::string disassembly;
+    tools.Disassemble(binary, &disassembly, SPV_BINARY_TO_TEXT_OPTION_FRIENDLY_NAMES);
+    WLOG("--- Disassembly: %s --- (id=%d)", title.c_str(), id);
+    WLOG("(id=%d)\n%s", id, disassembly.c_str());
+    print_spirv_code("  ", binary.size() * 4, binary.data());
+}
+
+void OptimizerMessageConsumer(spv_message_level_t level, const char* source,
+    const spv_position_t& position, const char* message, int id) {
+#define MSG "%s (id=%d) (%s:%d)", message, id, source, position.line
+    switch (level) {
+    case SPV_MSG_FATAL:
+    case SPV_MSG_INTERNAL_ERROR:
+    case SPV_MSG_ERROR:
+        WLOGE("SPIRV Error: " MSG)
+        break;
+    case SPV_MSG_WARNING:
+        WLOGE("SPIRV Warning: " MSG)
+        break;
+    case SPV_MSG_INFO:
+        WLOG("SPIRV Info: " MSG)
+        break;
+    default:
+        break;
+    }
+}
+
+extern "C"
+int optimize_spirv_for_size(const uint32_t* spirv_binary, size_t spirv_word_count, struct SpirvCode* out) {
+    spvtools::Optimizer optimizer(SPV_ENV_VULKAN_1_1_SPIRV_1_4);
+
+    optimizer.SetMessageConsumer([&](spv_message_level_t level, const char* source, const spv_position_t& position, const char* message) {
+        OptimizerMessageConsumer(level, source, position, message, 0);
+    });
+
+    optimizer.RegisterPass(spvtools::CreateStripDebugInfoPass());
+    optimizer.RegisterPass(spvtools::CreateAggressiveDCEPass());
+    optimizer.RegisterPass(spvtools::CreateCompactIdsPass());
+
+    optimizer.RegisterPerformancePasses(); // For -O
+    optimizer.RegisterSizePasses();        // For -Os
+
+    WLOGD("Original SPIR-V Word Count %d", spirv_word_count);
+
+    std::vector<uint32_t> optimized_binary;
+    bool success = optimizer.Run(spirv_binary, spirv_word_count, &optimized_binary);
+
+    if (!success) {
+        WLOGE("SPIRV editing failed");
+        return 1;
+    }
+
+    WLOGD("Optimized SPIR-V Word Count %d", optimized_binary.size());
+
+    // LogDisassembly("Optimized", optimized_binary);
+
+    out->spirv_word_count = optimized_binary.size();
+    out->spirv_code = static_cast<uint32_t*>(malloc(optimized_binary.size() * 4));
+    if (!out->spirv_code) {
+        WLOGE("Failed to allocate memory for optimized SPIR-V");
+        return 1;
+    }
+    std::memcpy(out->spirv_code, optimized_binary.data(), optimized_binary.size() * 4);
+
+    return 0;
+}
+
+
+extern "C"
+int lower_eliminate_clip_distance(const uint32_t* spirv_binary, size_t spirv_word_count, struct SpirvCode* out) {
+    _Atomic static int counter = 0;
+    int id = counter++;
+    spvtools::Optimizer optimizer(SPV_ENV_VULKAN_1_1_SPIRV_1_4);
+
+    optimizer.SetMessageConsumer([&](spv_message_level_t level, const char* source, const spv_position_t& position, const char* message) {
+        OptimizerMessageConsumer(level, source, position, message, id);
+    });
+
+    // Mali specific pass
+    optimizer.RegisterPass(spvtools::CreateRemoveClipCullDistPass());
+
+    if (CHECK_FLAG("SPIRV_AGGRESSIVE_DCE")) {
+        optimizer.RegisterPass(spvtools::CreateAggressiveDCEPass());
+    }
+
+    WLOGD("Original SPIR-V Word Count %d (id=%d)", spirv_word_count, id);
+
+    std::vector<uint32_t> optimized_binary;
+    bool success = optimizer.Run(spirv_binary, spirv_word_count, &optimized_binary);
+
+    if (!success) {
+        WLOGE("SPIRV editing failed");
+        return 1;
+    }
+
+    WLOGD("Lowered SPIR-V Word Count %d (id=%d)", optimized_binary.size(), id);
+
+    if (optimized_binary.size() != spirv_word_count) {
+        if (CHECK_FLAG("LOG_DISASSEMBLY"))
+            LogDisassembly("Original", {spirv_binary, spirv_binary+spirv_word_count}, id);
+        LogDisassembly("Lowered", optimized_binary, id);
+    }
+
+    out->spirv_word_count = optimized_binary.size();
+    out->spirv_code = static_cast<uint32_t*>(malloc(optimized_binary.size() * 4));
+    if (!out->spirv_code) {
+        WLOGE("Failed to allocate memory for optimized SPIR-V (id=%d)", id);
+        return 1;
+    }
+    std::memcpy(out->spirv_code, optimized_binary.data(), optimized_binary.size() * 4);
+
+    return 0;
+}
