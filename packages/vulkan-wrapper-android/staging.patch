+
+// --- Shared Memory for Optimization ---
+shared uvec4 shared_block_data[4]; // One 128-bit block for each 4x4 quad-group in the 8x8 workgroup.
+
+// --- Main Decode Function ---
+void main() {
+    // Calculate pixel coordinate from workgroup and local invocation IDs
+    ivec2 coord = ivec2(gl_WorkGroupID.xy) * 8 + ivec2(gl_LocalInvocationID.xy);
+
+    // Check if this invocation is out of bounds for the destination image
+    if (coord.x >= push_constants.dst_width || coord.y >= push_constants.dst_height) {
+        return;
+    }
+
+    ivec2 local_coords = ivec2(gl_LocalInvocationID.xy); // on 8x8 warp grid
+    // The first worker in the 4x4 squad is the leader who's responsible for fetching data
+    bool is_leader = (local_coords.x % 4 == 0) && (local_coords.y % 4 == 0);
+    int shared_idx = (local_coords.y / 4) * 2 + (local_coords.x / 4);
+
+    // Load the 128-bit block data into shared memory if this invocation is a leader
+    if (is_leader) {
+        ivec2 block_coord = coord / 4;
+        uint block_stride = push_constants.srcRowLength / 4;
+        uint block_index = block_coord.y * block_stride + block_coord.x;
+        uint buffer_offset = block_index * 4;
+        shared_block_data[shared_idx] = uvec4(
+            srcBuffer.data[buffer_offset + 0], srcBuffer.data[buffer_offset + 1],
+            srcBuffer.data[buffer_offset + 2], srcBuffer.data[buffer_offset + 3]
+        );
+    }
+    
+    // Synchronize to ensure all leaders have written their data before any invocation reads it
+    barrier();
+    // All invocations read the shared memory (only leaders fetch from main memory)
+    uvec4 payload = shared_block_data[shared_idx];
+
+    // Decode the local pixel this thread is responsible in the 4x4 grid
+    ivec2 tile_coord = coord % 4;
+    int linear_pixel = 4 * tile_coord.y + tile_coord.x;
+
+    DecodedInterpolation interp;
+
+    bool is_signed = (push_constants.srcFormat == 144); // VK_FORMAT_BC6H_SFLOAT_BLOCK
+
+    int mode = extract_bits(payload, 0, 5);
+    int part_index = extract_bits(payload, 77, 5);
+    int part = (partition_table2[part_index] >> linear_pixel) & 1;
+    int anchor_pixel = anchor_table2[part_index];
+
+    // The switch statement is the same, but now passes `is_signed` to the decode functions.
+    if ((mode & 2) == 0) {
+        if ((mode & 1) != 0)
+            interp = decode_bc6_mode1(payload, linear_pixel, part, anchor_pixel, is_signed);
+        else
+            interp = decode_bc6_mode0(payload, linear_pixel, part, anchor_pixel, is_signed);
+    } else {
+        switch (mode) {
+        case 2: interp = decode_bc6_mode2(payload, linear_pixel, part, anchor_pixel, is_signed); break;
+        case 3: interp = decode_bc6_mode3(payload, linear_pixel, is_signed); break;
+        case 6: interp = decode_bc6_mode6(payload, linear_pixel, part, anchor_pixel, is_signed); break;
+        case 7: interp = decode_bc6_mode7(payload, linear_pixel, is_signed); break;
+        case 10: interp = decode_bc6_mode10(payload, linear_pixel, part, anchor_pixel, is_signed); break;
+        case 11: interp = decode_bc6_mode11(payload, linear_pixel, is_signed); break;
+        case 14: interp = decode_bc6_mode14(payload, linear_pixel, part, anchor_pixel, is_signed); break;
+        case 15: interp = decode_bc6_mode15(payload, linear_pixel, is_signed); break;
+        case 18: interp = decode_bc6_mode18(payload, linear_pixel, part, anchor_pixel, is_signed); break;
+        case 22: interp = decode_bc6_mode22(payload, linear_pixel, part, anchor_pixel, is_signed); break;
+        case 26: interp = decode_bc6_mode26(payload, linear_pixel, part, anchor_pixel, is_signed); break;
+        case 30: interp = decode_bc6_mode30(payload, linear_pixel, part, anchor_pixel, is_signed); break;
+        default: interp = DecodedInterpolation(ivec3(0x3c00, 0, 0x3c00), ivec3(0x3c00, 0, 0x3c00), 0); break;
+        }
+    }
+
+    ivec3 rgba_result = interpolate_endpoint(interp);
+    if (is_signed)
+    {
+        ivec3 neg_result = 0x8000 | (((-rgba_result) * 31) >> 5);
+        ivec3 pos_result = (rgba_result * 31) >> 5;
+        rgba_result = mix(pos_result, neg_result, lessThan(rgba_result, ivec3(0)));
+
+        // Fixup for -0.0. Seems to not be emitted by hardware decoder.
+        rgba_result = mix(rgba_result, ivec3(0), equal(rgba_result, ivec3(0x8000)));
+    } else {
+        rgba_result = (rgba_result * 31) >> 6;
+    }
+
+    // Calculate final destination coordinates and write to buffer
+    ivec2 final_dst_coord = ivec2(push_constants.offsetx, push_constants.offsety) + coord;
+#ifdef USE_IMAGE_VIEW_OUTPUT
+    uvec4 final_rbga_color = uvec4(rgba_result, 0x3c00); // Alpha is always 1.0 for BC6.
+    // vec4 final_rbga_color = vec4(1.0, 0.0, 1.0, 1.0); // Convert to normalized float and set alpha to 1.0
+    imageStore(dstImage, final_dst_coord, final_rbga_color);
+#else
+    // Pack into AABBGGRR format. Alpha is always 1.0 for BC6.
+    uint packed_color = (0xFF << 24) | (rgb8.b << 16) | (rgb8.g << 8) | rgb8.r;
+    // Calculate the linear index into the destination buffer using its row length (dst_width is the stride)
+    int dst_index = int(final_dst_coord.y * push_constants.dst_width + final_dst_coord.x);
+    dstBuffer.data[dst_index] =  packed_color;
+#endif
+}
