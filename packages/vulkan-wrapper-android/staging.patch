+            *out_pnext_ptr = (VkBaseOutStructure *) VK_ALLOC(VkPhysicalDeviceShaderReplicatedCompositesFeaturesEXT); // Set ext->pnext = vk_alloc
+            unwrap_VkPhysicalDeviceShaderReplicatedCompositesFeaturesEXT_members_only(device, (VkPhysicalDeviceShaderReplicatedCompositesFeaturesEXT *)*out_pnext_ptr, (const VkPhysicalDeviceShaderReplicatedCompositesFeaturesEXT *)pnext);
+            break;
+        default:
+            /* The calculate function allocated space, now we copy it. */
+            memcpy(*out_pnext_ptr, pnext, vk_structure_type_size(pnext));
+            break;
+        }
+        out_pnext_ptr = &(*out_pnext_ptr)->pNext;
+    }
+    *out_pnext_ptr = NULL;
+}
