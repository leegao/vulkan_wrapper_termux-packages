+    'VkPresentFrameTokenGGP',
+    'VkRefreshObjectKHR',
+    'VkRefreshObjectListKHR',
+    'VkSciSyncAttributesInfoNV',
+    'VkScreenBufferFormatPropertiesQNX',
+    'VkScreenBufferPropertiesQNX',
+    'VkScreenSurfaceCreateInfoQNX',
+    'VkSemaphoreGetSciSyncInfoNV',
