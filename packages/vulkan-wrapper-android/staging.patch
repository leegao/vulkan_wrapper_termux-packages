+        ep1 = ivec3(r1, g1, b1);
+    }
+
+    ep0 = unquantize_endpoint(ep0, 6, is_signed);
+    ep1 = unquantize_endpoint(ep1, 6, is_signed);
+
+    int index = extract_bits(
