+    'VkExportMetalBufferInfoEXT',
+    'VkExportMetalCommandQueueInfoEXT',
+    'VkExportMetalDeviceInfoEXT',
+    'VkExportMetalIOSurfaceInfoEXT',
+    'VkExportMetalObjectCreateInfoEXT',
+    'VkExportMetalObjectsInfoEXT',
