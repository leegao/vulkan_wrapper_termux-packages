+    'VkStreamDescriptorSurfaceCreateInfoGGP',
+    'VkSurfaceCapabilitiesFullScreenExclusiveEXT',
+    'VkSurfaceFullScreenExclusiveInfoEXT',
+    'VkSurfaceFullScreenExclusiveWin32InfoEXT',
