+    ivec3 ep0 = ivec3(r0, g0, b0);
+    ivec3 ep1 = ivec3(r1, g1, b1);
+    ep0 = unquantize_endpoint(ep0, 16, is_signed);
+    ep1 = unquantize_endpoint(ep1, 16, is_signed);
